rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /customers/{customerId} {
      allow read, write: if isSignedIn();
    }

    match /jobWorkOrders/{jobWorkId} {
      allow read, write: if isSignedIn();
    }

    match /jobWorkInvoices/{invoiceId} {
      allow read, write: if isSignedIn();
    }

    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read, write: if isSignedIn();
    }

    match /salesOrders/{salesOrderId} {
      allow read, write: if isSignedIn();
    }

    match /salesInvoices/{invoiceId} {
      allow read, write: if isSignedIn();
    }

    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    match /suppliers/{supplierId} {
      allow read, write: if isSignedIn();
    }

    match /rawMaterials/{materialId} {
      allow read, write: if isSignedIn();
    }

    match /stockTransactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    match /productionBatches/{batchId} {
      allow read, write: if isSignedIn();
    }

    match /finishedGoods/{finishedGoodId} {
      allow read, write: if isSignedIn();
    }

    match /inventoryTransactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    // Tighten these rules as modules are implemented in later sprints.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
