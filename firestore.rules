rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myFactory() {
      return me().factoryId;
    }

    function myRole() {
      return me().role;
    }

    function myEmployeeId() {
      return me().get('employeeId', '');
    }

    function effectiveRole() {
      return myRole() == 'manager' ? 'factoryManager' : myRole();
    }

    function isOwner() {
      return effectiveRole() == 'owner';
    }

    function isViewer() {
      return effectiveRole() == 'viewer';
    }

    function isDriver() {
      return effectiveRole() == 'driver';
    }

    function myStatus() {
      return me().get('status', 'active');
    }

    function isActiveUser() {
      return myStatus() != 'disabled';
    }

    function userProfileExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function ownerFactoryBootstrap() {
      return signedIn() &&
        !userProfileExists() &&
        request.resource.data.ownerUserId == request.auth.uid &&
        request.resource.data.status == 'active' &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.keys().hasAll([
          'name', 'ownerUserId', 'status', 'createdAt', 'updatedAt'
        ]) &&
        !request.resource.data.keys().hasAny(['id']);
    }

    function ownerUserBootstrap(userId) {
      return signedIn() &&
        request.auth.uid == userId &&
        !userProfileExists() &&
        request.resource.data.role == 'owner' &&
        request.resource.data.status == 'active' &&
        request.resource.data.onboardingComplete == true &&
        request.resource.data.email is string &&
        request.resource.data.name is string &&
        request.resource.data.factoryId is string &&
        request.resource.data.factoryId.size() > 0 &&
        request.resource.data.keys().hasAll([
          'email', 'name', 'role', 'factoryId', 'status',
          'onboardingComplete', 'createdAt'
        ]) &&
        !request.resource.data.keys().hasAny(['employeeId', 'photoUrl']) &&
        exists(/databases/$(database)/documents/factories/$(request.resource.data.factoryId)) &&
        get(/databases/$(database)/documents/factories/$(request.resource.data.factoryId)).data.ownerUserId == request.auth.uid;
    }

    function sameFactoryExisting() {
      return resource.data.factoryId == myFactory();
    }

    function sameFactoryIncoming() {
      return request.resource.data.factoryId == myFactory();
    }

    function canReadFactoryDoc() {
      return signedIn() && isActiveUser() && sameFactoryExisting();
    }

    function canWriteFactoryDoc() {
      return signedIn() && isActiveUser() && !isViewer() && sameFactoryIncoming();
    }

    function canReadFinancial() {
      return effectiveRole() in ['owner', 'accountant', 'factoryManager', 'salesStaff', 'jobWorkClerk'];
    }

    function canWriteFinancial() {
      return effectiveRole() in ['owner', 'accountant', 'salesStaff'];
    }

    function canReadOperations() {
      return effectiveRole() in [
        'owner', 'factoryManager', 'supervisor', 'storeKeeper',
        'jobWorkClerk', 'salesStaff', 'accountant'
      ];
    }

    function canWriteOperations() {
      return effectiveRole() in ['owner', 'factoryManager', 'supervisor', 'storeKeeper', 'jobWorkClerk'];
    }

    function canReadProduction() {
      return effectiveRole() in ['owner', 'factoryManager', 'supervisor', 'storeKeeper', 'jobWorkClerk', 'accountant'];
    }

    function canWriteProduction() {
      return effectiveRole() in ['owner', 'factoryManager', 'supervisor'];
    }

    function canReadLabour() {
      return effectiveRole() in ['owner', 'factoryManager', 'supervisor', 'accountant'];
    }

    function canWriteLabour() {
      return effectiveRole() in ['owner', 'factoryManager', 'supervisor'];
    }

    function canReadDelivery() {
      return signedIn() && isActiveUser() && sameFactoryExisting() && (
        !isDriver() || resource.data.driverEmployeeId == myEmployeeId()
      );
    }

    function canWriteDelivery() {
      return signedIn() && isActiveUser() && sameFactoryIncoming() && !isViewer() && (
        isOwner() ||
        effectiveRole() in ['factoryManager', 'salesStaff'] ||
        (isDriver() &&
          resource.data.driverEmployeeId == myEmployeeId() &&
          request.resource.data.driverEmployeeId == myEmployeeId())
      );
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        (isOwner() && resource.data.factoryId == myFactory())
      );
      allow create: if ownerUserBootstrap(userId);
      allow update: if signedIn() && isActiveUser() && (
        request.auth.uid == userId ||
        (isOwner() &&
          resource.data.factoryId == myFactory() &&
          request.resource.data.factoryId == myFactory())
      );
    }

    // Owner bootstrap: first-time signup writes factory + user via client batch (S32).
    match /factories/{factoryId} {
      allow read: if signedIn() && isActiveUser() && factoryId == myFactory();
      allow create: if ownerFactoryBootstrap();
      allow update: if isOwner() && isActiveUser() && factoryId == myFactory();
      allow delete: if false;
    }

    match /invites/{inviteId} {
      allow read: if signedIn() && isActiveUser() && (
        (isOwner() && resource.data.factoryId == myFactory()) ||
        (resource.data.email == request.auth.token.email &&
          resource.data.status == 'pending')
      );
      allow create: if false;
      allow update: if signedIn() && isActiveUser() && isOwner() &&
        resource.data.factoryId == myFactory() &&
        request.resource.data.factoryId == resource.data.factoryId &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.invitedBy == resource.data.invitedBy &&
        request.resource.data.status == 'revoked';
      allow delete: if false;
    }

    match /customers/{customerId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create, update: if canWriteFactoryDoc() && canWriteFinancial();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /jobWorkOrders/{jobWorkId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && canWriteOperations();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /jobWorkInvoices/{invoiceId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create, update: if canWriteFactoryDoc() && canWriteFinancial();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /payments/{paymentId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create, update: if canWriteFactoryDoc() && canWriteFinancial();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /paymentReminders/{reminderId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create: if canWriteFactoryDoc() && canReadFinancial();
      allow update, delete: if isOwner() && sameFactoryExisting();
    }

    match /notifications/{notifId} {
      allow read: if canReadFactoryDoc();
      allow create, update: if canWriteFactoryDoc();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /salesOrders/{salesOrderId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create, update: if canWriteFactoryDoc() && canWriteFinancial();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /salesInvoices/{invoiceId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create, update: if canWriteFactoryDoc() && canWriteFinancial();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /expenses/{expenseId} {
      allow read: if canReadFactoryDoc() && effectiveRole() in ['owner', 'accountant', 'factoryManager'];
      allow create, update: if canWriteFactoryDoc() && effectiveRole() in ['owner', 'accountant'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /suppliers/{supplierId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && canWriteOperations();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /rawMaterials/{materialId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && effectiveRole() in ['owner', 'factoryManager', 'storeKeeper'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /stockTransactions/{transactionId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && effectiveRole() in ['owner', 'factoryManager', 'storeKeeper'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /productionBatches/{batchId} {
      allow read: if canReadFactoryDoc() && canReadProduction();
      allow create, update: if canWriteFactoryDoc() && canWriteProduction();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /finishedGoods/{finishedGoodId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && effectiveRole() in ['owner', 'factoryManager', 'storeKeeper'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /inventoryTransactions/{transactionId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && effectiveRole() in ['owner', 'factoryManager', 'storeKeeper'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /employees/{employeeId} {
      allow read: if canReadFactoryDoc() && canReadLabour();
      allow create, update: if canWriteFactoryDoc() && canWriteLabour();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /attendanceRecords/{recordId} {
      allow read: if canReadFactoryDoc() && canReadLabour();
      allow create, update: if canWriteFactoryDoc() && canWriteLabour();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /deliveries/{deliveryId} {
      allow read: if canReadDelivery();
      allow create: if signedIn() && isActiveUser() && sameFactoryIncoming() && !isViewer() && !isDriver() &&
        effectiveRole() in ['owner', 'factoryManager', 'salesStaff'];
      allow update: if canWriteDelivery();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /equipment/{equipmentId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && effectiveRole() in ['owner', 'factoryManager', 'supervisor'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /maintenanceLogs/{logId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && effectiveRole() in ['owner', 'factoryManager', 'supervisor'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /qualityChecks/{qcId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && effectiveRole() in ['owner', 'factoryManager', 'supervisor', 'jobWorkClerk'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
