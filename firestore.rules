rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myFactory() {
      return me().factoryId;
    }

    function myRole() {
      return me().role;
    }

    function myEmployeeId() {
      return me().get('employeeId', '');
    }

    function isOwner() {
      return myRole() == 'owner';
    }

    function isViewer() {
      return myRole() == 'viewer';
    }

    function isDriver() {
      return myRole() == 'driver';
    }

    function sameFactoryExisting() {
      return resource.data.factoryId == myFactory();
    }

    function sameFactoryIncoming() {
      return request.resource.data.factoryId == myFactory();
    }

    function canReadFactoryDoc() {
      return signedIn() && sameFactoryExisting();
    }

    function canWriteFactoryDoc() {
      return signedIn() && !isViewer() && sameFactoryIncoming();
    }

    function canReadFinancial() {
      return myRole() in ['owner', 'accountant', 'factoryManager', 'salesStaff', 'jobWorkClerk'];
    }

    function canWriteFinancial() {
      return myRole() in ['owner', 'accountant', 'salesStaff'];
    }

    function canReadOperations() {
      return myRole() in [
        'owner', 'factoryManager', 'supervisor', 'storeKeeper',
        'jobWorkClerk', 'salesStaff', 'accountant'
      ];
    }

    function canWriteOperations() {
      return myRole() in ['owner', 'factoryManager', 'supervisor', 'storeKeeper', 'jobWorkClerk'];
    }

    function canReadProduction() {
      return myRole() in ['owner', 'factoryManager', 'supervisor', 'storeKeeper', 'jobWorkClerk', 'accountant'];
    }

    function canWriteProduction() {
      return myRole() in ['owner', 'factoryManager', 'supervisor'];
    }

    function canReadLabour() {
      return myRole() in ['owner', 'factoryManager', 'supervisor', 'accountant'];
    }

    function canWriteLabour() {
      return myRole() in ['owner', 'factoryManager', 'supervisor'];
    }

    function canReadDelivery() {
      return signedIn() && sameFactoryExisting() && (
        !isDriver() || resource.data.driverEmployeeId == myEmployeeId()
      );
    }

    function canWriteDelivery() {
      return signedIn() && sameFactoryIncoming() && !isViewer() && (
        isOwner() ||
        myRole() in ['factoryManager', 'salesStaff'] ||
        (isDriver() &&
          resource.data.driverEmployeeId == myEmployeeId() &&
          request.resource.data.driverEmployeeId == myEmployeeId())
      );
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        (isOwner() && resource.data.factoryId == myFactory())
      );
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        request.auth.uid == userId ||
        (isOwner() &&
          resource.data.factoryId == myFactory() &&
          request.resource.data.factoryId == myFactory())
      );
    }

    match /factories/{factoryId} {
      allow read: if signedIn() && factoryId == myFactory();
      allow create, update: if isOwner() && factoryId == myFactory();
      allow delete: if false;
    }

    match /customers/{customerId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create, update: if canWriteFactoryDoc() && canWriteFinancial();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /jobWorkOrders/{jobWorkId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && canWriteOperations();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /jobWorkInvoices/{invoiceId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create, update: if canWriteFactoryDoc() && canWriteFinancial();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /payments/{paymentId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create, update: if canWriteFactoryDoc() && canWriteFinancial();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /paymentReminders/{reminderId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create: if canWriteFactoryDoc() && canReadFinancial();
      allow update, delete: if isOwner() && sameFactoryExisting();
    }

    match /notifications/{notifId} {
      allow read: if canReadFactoryDoc();
      allow create, update: if canWriteFactoryDoc();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /salesOrders/{salesOrderId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create, update: if canWriteFactoryDoc() && canWriteFinancial();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /salesInvoices/{invoiceId} {
      allow read: if canReadFactoryDoc() && canReadFinancial();
      allow create, update: if canWriteFactoryDoc() && canWriteFinancial();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /expenses/{expenseId} {
      allow read: if canReadFactoryDoc() && myRole() in ['owner', 'accountant', 'factoryManager'];
      allow create, update: if canWriteFactoryDoc() && myRole() in ['owner', 'accountant'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /suppliers/{supplierId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && canWriteOperations();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /rawMaterials/{materialId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && myRole() in ['owner', 'factoryManager', 'storeKeeper'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /stockTransactions/{transactionId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && myRole() in ['owner', 'factoryManager', 'storeKeeper'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /productionBatches/{batchId} {
      allow read: if canReadFactoryDoc() && canReadProduction();
      allow create, update: if canWriteFactoryDoc() && canWriteProduction();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /finishedGoods/{finishedGoodId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && myRole() in ['owner', 'factoryManager', 'storeKeeper'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /inventoryTransactions/{transactionId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && myRole() in ['owner', 'factoryManager', 'storeKeeper'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /employees/{employeeId} {
      allow read: if canReadFactoryDoc() && canReadLabour();
      allow create, update: if canWriteFactoryDoc() && canWriteLabour();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /attendanceRecords/{recordId} {
      allow read: if canReadFactoryDoc() && canReadLabour();
      allow create, update: if canWriteFactoryDoc() && canWriteLabour();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /deliveries/{deliveryId} {
      allow read: if canReadDelivery();
      allow create: if signedIn() && sameFactoryIncoming() && !isViewer() && !isDriver() &&
        myRole() in ['owner', 'factoryManager', 'salesStaff'];
      allow update: if canWriteDelivery();
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /equipment/{equipmentId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && myRole() in ['owner', 'factoryManager', 'supervisor'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /maintenanceLogs/{logId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && myRole() in ['owner', 'factoryManager', 'supervisor'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /qualityChecks/{qcId} {
      allow read: if canReadFactoryDoc() && canReadOperations();
      allow create, update: if canWriteFactoryDoc() && myRole() in ['owner', 'factoryManager', 'supervisor', 'jobWorkClerk'];
      allow delete: if isOwner() && sameFactoryExisting();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
